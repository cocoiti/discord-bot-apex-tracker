{
  "name": "discord-bot-apex-tracker",
  "version": "1.0.0",
  "description": "Apex Legends RP tracker Discord bot",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "rank": "tsx src/cli/rank.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "keywords": [
    "discord",
    "apex-legends",
    "tracker"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "discord.js": "^14.14.0",
    "dotenv": "^16.3.0",
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.8"
  }
}
